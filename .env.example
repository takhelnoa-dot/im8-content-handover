# IM8 Content Automation - Required Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your actual .env file.

# --- AI APIs ---
ANTHROPIC_API_KEY=           # Get from console.anthropic.com
OPENAI_API_KEY=              # Get from platform.openai.com (used for Whisper transcription + embeddings)
PERPLEXITY_API_KEY=          # Get from perplexity.ai/settings/api (used by ambassador brief for creator research)

# --- Slack ---
SLACK_BOT_TOKEN=             # Create a Slack app at api.slack.com, add bot scopes: chat:write, channels:history, files:read
# The bot must be invited to these IM8 channels:
#   C0ASDVB3FB8  (IM8 briefing channel - editor brief + ambassador brief triggers)
#   C0AGEM919QV  (IM8 Ad-Production-Internal - weekly sprint reads from here)
#   C0AP09Z2DEU  (IM8 Customer Reviews - review caller watcher)

# --- Google Drive / Sheets ---
# Option A: OAuth2 (recommended for local use)
GOOGLE_OAUTH_CREDENTIALS_PATH=./secrets/client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=./secrets/token.json
# Option B: Service Account (recommended for Render/cloud deploy)
GOOGLE_SERVICE_ACCOUNT_JSON=  # base64-encoded service account JSON key

GOOGLE_DRIVE_FOLDER_ID=      # Root Drive folder the bot has access to

# --- AssemblyAI (transcription terminal diarization) ---
ASSEMBLYAI_API_KEY=          # Get from assemblyai.com

# --- Foreplay (ad research - used by weekly sprint brief pipeline) ---
FOREPLAY_API_KEY=            # Get from app.foreplay.co/settings

# --- Transcription Terminal ---
DASHBOARD_PASSWORD=          # Single shared password for the terminal web UI
TERMINAL_UPLOAD_DRIVE_FOLDER_ID=  # Drive folder ID for direct MP4 uploads
